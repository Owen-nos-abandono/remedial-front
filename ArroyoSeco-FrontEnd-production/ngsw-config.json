{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.csr.html",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ],
        "urls": [
          "https://fonts.googleapis.com/**",
          "https://fonts.gstatic.com/**"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/**/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-public-content",
      "urls": [
        "/api/alojamientos",
        "/api/alojamientos/**",
        "/api/Gastronomias",
        "/api/Gastronomias/**",
        "https://arroyoseco-api-production-fcae.up.railway.app/api/alojamientos",
        "https://arroyoseco-api-production-fcae.up.railway.app/api/alojamientos/**",
        "https://arroyoseco-api-production-fcae.up.railway.app/api/Gastronomias",
        "https://arroyoseco-api-production-fcae.up.railway.app/api/Gastronomias/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 100,
        "maxAge": "1d",
        "timeout": "5s"
      }
    },
    {
      "name": "api-user-data",
      "urls": [
        "/api/resenas/**",
        "/api/reservas/**",
        "/api/Reservas/**",
        "/api/notificaciones/**",
        "/api/Oferentes/**",
        "/api/auth/me",
        "/api/auth/perfil",
        "/api/admin/**",
        "/api/solicitudesoferente**",
        "/api/SolicitudesOferente**",
        "/api/ReservasGastronomia/**",
        "/api/ResenasGastronomia",
        "/api/ResenasGastronomia/**",
        "/api/estadisticas/**",
        "/api/usuarios/**",
        "https://arroyoseco-api-production-fcae.up.railway.app/api/resenas/**",
        "https://arroyoseco-api-production-fcae.up.railway.app/api/ResenasGastronomia",
        "https://arroyoseco-api-production-fcae.up.railway.app/api/ResenasGastronomia/**",
        "https://arroyoseco-api-production-fcae.up.railway.app/api/reservas/**",
        "https://arroyoseco-api-production-fcae.up.railway.app/api/Reservas/**",
        "https://arroyoseco-api-production-fcae.up.railway.app/api/notificaciones/**",
        "https://arroyoseco-api-production-fcae.up.railway.app/api/Oferentes/**",
        "https://arroyoseco-api-production-fcae.up.railway.app/api/auth/me",
        "https://arroyoseco-api-production-fcae.up.railway.app/api/auth/perfil",
        "https://arroyoseco-api-production-fcae.up.railway.app/api/admin/**",
        "https://arroyoseco-api-production-fcae.up.railway.app/api/solicitudesoferente**",
        "https://arroyoseco-api-production-fcae.up.railway.app/api/SolicitudesOferente**",
        "https://arroyoseco-api-production-fcae.up.railway.app/api/ReservasGastronomia/**",
        "https://arroyoseco-api-production-fcae.up.railway.app/api/estadisticas/**",
        "https://arroyoseco-api-production-fcae.up.railway.app/api/usuarios/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 150,
        "maxAge": "12h",
        "timeout": "5s"
      }
    },
    {
      "name": "api-public-media",
      "urls": [
        "/api/storage/public/**",
        "https://arroyoseco-api-production-fcae.up.railway.app/api/storage/public/**"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 200,
        "maxAge": "30d"
      }
    }
  ]
}
