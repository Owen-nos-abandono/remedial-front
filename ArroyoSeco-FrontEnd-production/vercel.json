{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/arroyo-seco/browser",
  "framework": "angular",
  "headers": [
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
